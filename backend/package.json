{
  "name": "neura-backend",
  "version": "1.0.0",
  "description": "NEURA Cognitive Banking Backend - Express + TypeScript",
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.cjs --platform=node --format=cjs --external:vite",
    "start": "node dist/index.cjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^0.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^12.3.0",
    "helmet": "^7.1.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.19.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}