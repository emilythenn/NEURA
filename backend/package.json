{
  "name": "neura-backend",
  "version": "1.0.0",
  "description": "NEURA Cognitive Banking Backend - Express + TypeScript",
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "dev": "tsx watch --ignore '../frontend' src/index.ts",
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.cjs --platform=node --format=cjs --external:vite",
    "start": "node dist/index.cjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@google-cloud/firestore": "^7.9.0",
    "@google/genai": "^0.4.0",
    "aws-lambda": "^1.0.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.10.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/express": "^4.17.17",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.23.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
